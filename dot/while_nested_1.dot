digraph G {
function_MAIN [shape=trapezium, label="F[_MAIN]"];
bb5 [shape=record,label="<b>BB[5]|{6: write -1|7: write -1|8: add 9 -3|10: add 11 -3|12: bra 9}"];
bb3 [shape=record,label="<b>BB[3]|{3: write -1}"];
bb6 [shape=record,label="<b>BB[6]|{13: \<empty\>|14: add 15 -3|18: bra 15}"];
bb2 [shape=record,label="<b>join\nBB[2]|{15: phi 14 -1|16: phi 9 -1|17: phi 11 -1|1: cmp -1 -2|2: bge 1 19}"];
bb7 [shape=record,label="<b>join\nBB[7]|{9: phi 8 -1|11: phi 10 -1|4: cmp 16 -2|5: bge 4 13}"];
bb1 [shape=record,label="<b>BB[1]|{-1: const #0|-2: const #3|-3: const #1}"];
bb4 [shape=record,label="<b>BB[4]|{19: \<empty\>}"];
function_MAIN:s -> bb1:n [arrowhead=icurve, penwidth=2];
bb1:s -> bb2:n;
bb3:s -> bb7:n;
bb7:s -> bb5:n [label="fall-through", color="#4ebf63", fontcolor="#4ebf63"];
bb5:s -> bb7:n [label="branch", color="#d26f4f", fontcolor="#d26f4f"];
bb7:s -> bb6:n [label="branch", color="#d26f4f", fontcolor="#d26f4f"];
bb2:s -> bb3:n [label="fall-through", color="#4ebf63", fontcolor="#4ebf63"];
bb6:s -> bb2:n [label="branch", color="#d26f4f", fontcolor="#d26f4f"];
bb2:s -> bb4:n [label="branch", color="#d26f4f", fontcolor="#d26f4f"];
bb7:s -> bb5:b [label="dom", style=dotted, color="#6b80d4", fontcolor="#6b80d4"];
bb3:s -> bb5:b [label="dom", style=dotted, color="#6b80d4", fontcolor="#6b80d4"];
bb2:s -> bb5:b [label="dom", style=dotted, color="#6b80d4", fontcolor="#6b80d4"];
bb2:s -> bb3:b [label="dom", style=dotted, color="#6b80d4", fontcolor="#6b80d4"];
bb7:s -> bb6:b [label="dom", style=dotted, color="#6b80d4", fontcolor="#6b80d4"];
bb3:s -> bb6:b [label="dom", style=dotted, color="#6b80d4", fontcolor="#6b80d4"];
bb2:s -> bb6:b [label="dom", style=dotted, color="#6b80d4", fontcolor="#6b80d4"];
bb3:s -> bb7:b [label="dom", style=dotted, color="#6b80d4", fontcolor="#6b80d4"];
bb2:s -> bb7:b [label="dom", style=dotted, color="#6b80d4", fontcolor="#6b80d4"];
bb2:s -> bb4:b [label="dom", style=dotted, color="#6b80d4", fontcolor="#6b80d4"];
}
