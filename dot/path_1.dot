digraph G {
function_MAIN [shape=trapezium, label="F[_MAIN]"];
bb7 [shape=record,label="<b>BB[7]|{8: \<empty\>|11: bra 10}"];
bb1 [shape=record,label="<b>BB[1]|{-1: const #1|-2: const #0}"];
bb6 [shape=record,label="<b>BB[6]|{6: write -1|7: bra 4}"];
bb2 [shape=record,label="<b>BB[2]|{1: cmp -1 -2|2: bge 1 9}"];
