function_MAIN:s -> bb1:n [arrowhead=icurve, penwidth=2];
bb1:s -> bb2:n;
bb3:s -> bb5:n;
bb5:s -> bb6:n [label="fall-through", color="#4ebf63", fontcolor="#4ebf63"];
